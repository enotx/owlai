{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Owl Data Analyzer",
  "version": "0.1.0",
  "identifier": "com.owl.analyzer",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Owl Data Analyzer",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main app capabilities",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:allow-execute",
            "shell:allow-open",
            "fs:allow-read-file",
            "fs:allow-read-dir"
          ]
        }
      ]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/python-backend"
    ],
    "resources": [
      "binaries/*"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}